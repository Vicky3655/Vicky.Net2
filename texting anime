/* 1. Setup the container for depth */
.con {
    display: flex;
    justify-content: center;
    gap: 30px;
    perspective: 1000px; /* Crucial for 3D rotation */
    margin-top: 20px;
}

/* 2. Style the icons for a heavy, metallic look */
.con img {
    width: 60px; /* Size based on your screenshot */
    height: auto;
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    transform-style: preserve-3d;
    filter: drop-shadow(0px 4px 5px rgba(0,0,0,0.4));
}

/* 3. Apply the "Thick" extrusion on hover */
.con img:hover {
    /* Tilt the icon to show off the thickness */
    transform: rotateX(20deg) rotateY(-20deg) translateZ(30px);

    /* Stacked shadows create the solid 3D side walls */
    filter: drop-shadow(1px 1px 0px #1a1a1a) 
            drop-shadow(2px 2px 0px #1a1a1a) 
            drop-shadow(3px 3px 0px #1a1a1a) 
            drop-shadow(4px 4px 0px #1a1a1a)
            drop-shadow(5px 5px 0px #000000)
            drop-shadow(15px 15px 20px rgba(0,0,0,0.6));
}
