.typewriter { overflow: hidden; white-space: nowrap; border-right: 3px solid gold; width: 0; animation: typing 3s steps(20) forwards, blink 0.75s infinite; } /* steps(20) = number of characters */ @keyframes typing { from { width: 0; } to { width: 20ch; } } @keyframes blink { 50% { border-color: transparent; } }
.hero h2{
    font-size: 60px;
    font-weight: bold;
    text-align: center;
    color: #E8D5A3;
    font-family: 'Nunito', sans-serif;}

.hero h2::before{
    content: "Chime Victor Chinagorom";
    animation: words 5s infinite ;
    width: 0;
}
    

.hero h2::after {
    content: "_";
    position: absolute;
    color: #C9A84C; 
    overflow: hidden; 
    white-space: nowrap;
    animation: 
    typing 20s steps(20) backwards,
    cursor 8s infinite;} 


@keyframes cursor {
    to{
        border-left: #A08040;
    
    }
}

@keyframes typing {
    10%,15%,30%,35%,50%,55%,70%,75%,90%,95%{
        width: 0;
    }
    5%,20%,25%,40%,45%,60%,65%,80%,85%{
        width:calc(100% + 8px) ;
    }
}

@keyframes words {
    0%,50%{
        content: 'Chime Victor Chinagorom';
    }
    51%,100%{
        content: "A.K.A Vicky"
    }
}

/* 1. Setup the Nav and Container for 3D */
nav {
    perspective: 1000px; /* Crucial: sets the depth of the 3D space */
}

.logo {
    display: flex;
    align-items: center;
    gap: 10px;
    cursor: pointer;
    transition: transform 0.5s ease;
    transform-style: preserve-3d; /* Allows the image to move in 3D */
    color: #ffc107; /* Matches the gold in your lion logo */
    font-weight: bold;
    text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
}

/* 2. Style the Logo Image specifically */
.logo img {
    width: 50px; /* Adjust size as needed */
    height: auto;
    border-radius: 50%;
    transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    /* Simple 3D shadow effect */
    box-shadow: 0 5px 15px rgba(0,0,0,0.3);
}

/* 3. The 3D Hover Effect */
.logo:hover {
    /* Tilts the whole logo group */
    transform: rotateY(15deg) rotateX(10deg) scale(1.1);
}

.logo:hover img {
    /* Makes the lion image "lift" off the page further than the text */
    transform: translateZ(30px);
    box-shadow: 10px 15px 25px rgba(0,0,0,0.5);
}

/* 4. Optional: Add a '3D thickness' to the text */
.logo:hover {
    text-shadow: 
        1px 1px 0px #b8860b,
        2px 2px 0px #8b6508,
        3px 3px 10px rgba(0,0,0,0.8);
}
.logo img {
    height: 100px;
    width: 100px;
    margin-left: 0px;
    border-radius: 50%;
}

