/* Container Setup */
.contact {
    perspective: 1000px;
    padding: 80px 10%;
    text-align: center;
}

.contact-info {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 25px;
    margin-top: 40px;
}

/* 3D Contact Card Styling */
.contact-item {
    background: #fdf5e6; /* Match your cream background */
    padding: 30px;
    border-radius: 15px;
    width: 250px;
    transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    transform-style: preserve-3d;
    cursor: pointer;
    /* Initial subtle shadow */
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    
    /* Animation hidden state */
    opacity: 0;
    transform: translateY(50px);
}

/* Icon Styling */
.contact-item .icon {
    width: 50px;
    height: 50px;
    color: #b8860b; /* Gold/Bronze color */
    margin-bottom: 15px;
    transition: transform 0.4s ease;
}

/* The Thick 3D Hover Effect */
.contact-item:hover {
    transform: rotateX(10deg) rotateY(-10deg) translateZ(20px) !important;
    background: #ffffff;
    /* Stacked shadows create the "thick" card side */
    box-shadow: 
        1px 1px 0px #d4af37, 
        2px 2px 0px #d4af37, 
        3px 3px 0px #b8860b, 
        4px 4px 0px #b8860b,
        20px 20px 40px rgba(0,0,0,0.3);
}

.contact-item:hover .icon {
    transform: translateZ(40px) scale(1.1);
}

/* Scroll Trigger Class */
.contact-item.show-card {
    opacity: 1;
    transform: translateY(0);
}

